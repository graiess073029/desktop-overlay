{
  "name": "desktop",
  "version": "1.0.0",
  "description": "My Desktop",
  "main": "dist/index.js",
  "type": "commonjs",
  "scripts": {
    "build:tsc": "node ./node_modules/typescript/bin/tsc --build tsconfig.main.json tsconfig.renderer.json",
    "clean": "node -e \"fs.rmSync('dist', { recursive: true, force: true })\" 2>nul || rm -rf dist",
    "copy:assets": "xcopy /E /I /Y assets dist\\assets 2>nul || robocopy assets dist\\assets /E /IS /IT || echo No assets to copy",
    "copy:renderer": "xcopy /E /I /Y renderer\\*.html dist\\renderer\\ 2>nul && xcopy /E /I /Y renderer\\*.css dist\\renderer\\ 2>nul || robocopy renderer dist\\renderer *.html *.css /E /IS /IT || echo No structural renderer layout files to copy",
    "copy:addon": "xcopy /E /I /Y addon dist\\addon 2>nul || robocopy addon dist\\addon /E /IS /IT || echo No addon to copy",
    "build": "npm run build:tsc && npm run copy:assets && npm run copy:renderer && npm run copy:addon",
    "watch": "node ./node_modules/typescript/bin/tsc --build tsconfig.main.json tsconfig.renderer.json --watch",
    "start": "electron .",
    "dev": "npm run build && electron .",
    "dist": "npm run build && electron-builder --win",
    "dist:dir": "npm run build && electron-builder --win --dir",
    "postinstall": "electron-builder install-app-deps"
  },
  "author": "Li 7wek",
  "license": "",
  "dependencies": {
    "csv-parser": "^3.2.0",
    "datatables.net-dt": "^2.3.5",
    "ffmpeg-static": "^5.3.0",
    "fluent-ffmpeg": "^2.1.3",
    "hwinfo-reader": "^1.0.1",
    "pidusage": "^4.0.1",
    "ps-list": "^9.0.0",
    "sharp": "^0.35.2",
    "systeminformation": "^5.27.11",
    "tail": "^2.2.6"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@types/electron": "^1.6.12",
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.14",
    "@types/webpack-env": "^1.18.8",
    "electron": "^39.2.4",
    "electron-builder": "^26.15.0",
    "electron-packager": "^17.1.2",
    "typescript": "^5.9.3"
  },
  "build": {
    "appId": "com.example.desktopOverlay",
    "productName": "Desktop Overlay",
    "copyright": "Copyright © 2026 Youssef Graiess",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "assets/**/*",
      "addon/**/*",
      "node_modules/**/*"
    ],
    "asar": true,
    "asarUnpack": [
      "addon/**/*",
      "dist/assets/**/*"
    ],
    "extraResources": [
      {
        "from": "assets",
        "to": "assets",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "addon",
        "to": "addon",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/tray-icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Desktop Overlay"
    },
    "portable": {
      "artifactName": "${productName}-Portable-${version}.${ext}"
    }
  }
}
